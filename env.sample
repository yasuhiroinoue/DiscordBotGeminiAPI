# Create at https://makersuite.google.com/
GOOGLE_AI_KEY = "input your key here"

# Create at https://discord.com/developers/applications
DISCORD_BOT_TOKEN = "input your key here"

# !img command enabled (true or false)
IMG_COMMANDS_ENABLED = "false"

# Debug settings
## Setting for saving cloud files locally (for debugging)
DEBUG_SAVE_CLOUD_FILES = "false"
## Setting for logging user IDs (for debugging)
DEBUG_LOG_USER_IDS = "false"

# Create at https://console.cloud.google.com/
GCP_PROJECT_ID = "your-gcp-project-id"
GCP_REGION = "us-central1"

# Gemini Model Settings
MODEL_ID = "gemini-3.1-pro-preview"
GEMINI_IMAGE_MODEL = "gemini-3-pro-image-preview"

# Discord Bot Access Control (Comma-separated User IDs, leave empty to allow all)
ALLOWED_USER_IDS = ""

# Debug settings (Directory for saving cloud files)
# DEBUG_FILES_DIR = "debug_files"
